{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/phase-server",
          "sidecar": true,
          "args": []
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write"
  ]
}
