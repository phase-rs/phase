{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AbilityFile",
  "description": "Root structure for per-card ability JSON files.",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "JSON Schema reference for editor autocompletion",
      "type": [
        "string",
        "null"
      ]
    },
    "abilities": {
      "description": "Spell and activated ability definitions",
      "type": "array",
      "items": {
        "$ref": "#/$defs/AbilityDefinition"
      }
    },
    "replacements": {
      "description": "Replacement effect definitions",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ReplacementDefinition"
      }
    },
    "statics": {
      "description": "Static ability definitions",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/StaticDefinition"
      }
    },
    "triggers": {
      "description": "Trigger definitions",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/TriggerDefinition"
      }
    }
  },
  "required": [
    "abilities"
  ],
  "$defs": {
    "AbilityCost": {
      "description": "Cost to activate an ability.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "cost": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "Mana"
            }
          },
          "required": [
            "type",
            "cost"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "Tap"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "amount": {
              "type": "integer",
              "format": "int32"
            },
            "type": {
              "type": "string",
              "const": "Loyalty"
            }
          },
          "required": [
            "type",
            "amount"
          ]
        },
        {
          "type": "object",
          "properties": {
            "target": {
              "$ref": "#/$defs/TargetSpec"
            },
            "type": {
              "type": "string",
              "const": "Sacrifice"
            }
          },
          "required": [
            "type",
            "target"
          ]
        },
        {
          "type": "object",
          "properties": {
            "costs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AbilityCost"
              }
            },
            "type": {
              "type": "string",
              "const": "Composite"
            }
          },
          "required": [
            "type",
            "costs"
          ]
        }
      ]
    },
    "AbilityDefinition": {
      "description": "Parsed ability definition with typed effect.",
      "type": "object",
      "properties": {
        "cost": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbilityCost"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "effect": {
          "$ref": "#/$defs/Effect"
        },
        "kind": {
          "$ref": "#/$defs/AbilityKind"
        },
        "remaining_params": {
          "description": "Parameters not consumed by the typed Effect during parsing.\nContains metadata like SubAbility, Execute, SpellDescription, Defined,\nConditionCompare, etc. Used by the compat params() method.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "sub_ability": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbilityDefinition"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "kind",
        "effect"
      ]
    },
    "AbilityKind": {
      "type": "string",
      "enum": [
        "Spell",
        "Activated",
        "Database"
      ]
    },
    "DamageAmount": {
      "description": "How to specify a damage amount -- either a fixed integer or a variable reference.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "Fixed"
            },
            "value": {
              "type": "integer",
              "format": "int32"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "Variable"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        }
      ]
    },
